@echo off setlocal enabledelayedexpansion REM Trading Bot Infrastructure Test Script REM Load environment variables call .env.docker.production REM Colors for output set RED=031 set GREEN=032 set YELLOW=033 set NC=000 REM Function to print test result call :print_result %ERRORLEVEL% "%~2" if %ERRORLEVEL% neq 0 ( exit /b %ERRORLEVEL% ) goto :eof :print_result if "%~1" equ "0" ( echo !GREEN![PASS]%NC% %~2 ) else ( echo !RED![FAIL]%NC% %~2 exit /b 1 ) goto :eof REM Test 1: Container status echo %YELLOW%=== Testing container status ===%NC% docker compose -f docker-compose.yml ps REM Give services time to initialize ping -n 10 127.0.0.1 >nul REM Test 2: TimescaleDB connection and basic functionality echo %YELLOW%=== Testing TimescaleDB ===%NC% docker exec trading_timescaledb pg_isready -U trading -d trading_bot >nul call :print_result %ERRORLEVEL% "TimescaleDB basic connectivity" docker exec trading_timescaledb psql -U trading -d trading_bot -c "SELECT 1;" >nul call :print_result %ERRORLEVEL% "TimescaleDB query execution" docker exec trading_timescaledb psql -U trading -d trading_bot -c "SELECT table_name FROM information_schema.tables WHERE table_schema = 'public';" | find /i "audit_events" >nul call :print_result %ERRORLEVEL% "TimescaleDB contains audit_events table" docker exec trading_timescaledb psql -U trading -d trading_bot -c "SELECT hypertable_relation_size('audit_events');" >nul call :print_result %ERRORLEVEL% "TimescaleDB audit hypertable exists" REM Test 3: Redis connection and basic functionality echo %YELLOW%=== Testing Redis ===%NC% docker exec trading_redis redis-cli -a "%REDIS_PASSWORD%" ping | find "PONG" >nul call :print_result %ERRORLEVEL% "Redis basic connectivity" docker exec trading_redis redis-cli -a "%REDIS_PASSWORD%" set test_key test_value >nul docker exec trading_redis redis-cli -a "%REDIS_PASSWORD%" get test_key | find "test_value" >nul call :print_result %ERRORLEVEL% "Redis set/get operations" docker exec trading_redis redis-cli -a "%REDIS_PASSWORD%" del test_key >nul call :print_result %ERRORLEVEL% "Redis delete operation" REM Test 4: Prometheus metrics echo %YELLOW%=== Testing Prometheus ===%NC% curl -s -f http://localhost:9090/-/healthy >nul call :print_result %ERRORLEVEL% "Prometheus health check" REM Test 5: Grafana availability echo %YELLOW%=== Testing Grafana ===%NC% curl -s -f "http://admin:%GRAFANA_PASSWORD%@localhost:3000/api/health" >nul call :print_result %ERRORLEVEL% "Grafana health check" REM Test 6: Network isolation echo %YELLOW%=== Testing network isolation ===%NC% docker exec trading_redis ping -n 1 timescaledb >nul call :print_result %ERRORLEVEL% "Redis can reach TimescaleDB" docker exec trading_timescaledb ping -n 1 redis >nul call :print_result %ERRORLEVEL% "TimescaleDB can reach Redis" REM Test 7: Audit trail features echo %YELLOW%=== Testing audit trail features ===%NC% docker exec trading_timescaledb psql -U trading -d trading_bot -c ^ "INSERT INTO audit_events (event_id, timestamp, event_type, source, details, checksum) ^ VALUES ('a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11', NOW(), 'test_event', 'test_script', '{}', 'test_checksum') ^ ON CONFLICT DO NOTHING;" >nul call :print_result %ERRORLEVEL% "Audit events insert permission" docker exec trading_timescaledb psql -U trading -d trading_bot -c ^ "UPDATE audit_events SET details = 'updated' WHERE event_type = 'test_event';" 2>&1 | find "Updates not permitted" >nul call :print_result %ERRORLEVEL% "Audit events update prevention" docker exec trading_timescaledb psql -U trading -d trading_bot -c ^ "DELETE FROM audit_events WHERE event_type = 'test_event';" 2>&1 | find "Deletion not permitted" >nul call :print_result %ERRORLEVEL% "Audit events delete prevention" REM Clean up docker exec trading_timescaledb psql -U trading -d trading_bot -c ^ "DELETE FROM audit_events WHERE event_type = 'test_event';" >nul echo %GREEN%=== All tests passed successfully! ===%NC% echo Infrastructure is ready for production.
