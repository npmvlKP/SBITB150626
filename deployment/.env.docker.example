# Docker environment variables - TEMPLATE
# Copy this file to .env.docker and fill in actual values
# .env.docker is gitignored (contains secrets)
# .env.docker.example is committed to git

# ============================================================
# REQUIRED: Generate secure random passwords for production
# ============================================================
# Database passwords
TIMESCALEDB_PASSWORD=<generate_with: openssl rand -base64 32>
GRAFANA_PASSWORD=<generate_with: openssl rand -base64 32>

# Redis
REDIS_PASSWORD=<generate_with: openssl rand -base64 32>

# Grafana secret key
GRAFANA_SECRET_KEY=<generate_with: openssl rand -base64 32>

# ============================================================
# DERIVED: Connection URLs (auto-generated after setting passwords)
# ============================================================
REDIS_URL=redis://redis:6379/0
TIMESCALEDB_URL=postgresql://trading:<TIMESCALEDB_PASSWORD>@timescaledb:5432/trading_bot
