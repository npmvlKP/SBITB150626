@echo off setlocal enabledelayedexpansion REM TimescaleDB Backup Script REM Configuration set BACKUP_DIR=.\backups\timescaledb set DATE=%date:~10,4%%date:~4,2%%date:~7,2%_%time:~0,2%%time:~3,2%%time:~6,2% set BACKUP_FILE=!BACKUP_DIR!\trading_bot_!DATE!.sql.gz set RETENTION_DAYS=7 set PG_USER=trading set PG_DATABASE=trading_bot set PG_HOST=timescaledb REM Ensure backup directory exists if not exist "!BACKUP_DIR!" mkdir "!BACKUP_DIR!" REM Create backup with compression echo Creating TimescaleDB backup... docker exec trading_timescaledb pg_dump -U %PG_USER% -d %PG_DATABASE% --format=custom ^ --blobs --verbose --compress=9 --file=/tmp/trading_dump.dump REM Copy backup file locally docker cp trading_timescaledb:/tmp/trading_dump.dump "!BACKUP_FILE!" REM Clean up temporary file on container docker exec trading_timescaledb del /f /q /tmp/trading_dump.dump REM Verify backup if exist "!BACKUP_FILE!" ( for %%F in ("!BACKUP_FILE!") do if %%~zF gtr 0 ( echo Backup created successfully: !BACKUP_FILE! for %%F in ("!BACKUP_FILE!") do echo Backup size: %%~zF ) else ( echo ERROR: Backup failed to create or is empty! exit /b 1 ) ) else ( echo ERROR: Backup file not created! exit /b 1 ) REM Clean up old backups echo Cleaning up old backups (older than %RETENTION_DAYS% days)... forfiles /P "!BACKUP_DIR!" /M trading_bot_*.sql.gz /D -%RETENTION_DAYS% /C "cmd /c del @file" REM Verify retention echo Current backups: dir /b "!BACKUP_DIR!" echo TimescaleDB backup completed successfully.
